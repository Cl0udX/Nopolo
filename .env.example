# Configuración de Nopolo
# Copia este archivo a .env y configura tus valores

# === API Configuration ===
API_HOST=0.0.0.0
API_PORT=8000

# === GUI Configuration ===
GUI_AUTO_START_API=false

# === Google Cloud TTS (Opcional) ===
# Si quieres usar Google Cloud TTS, descarga las credenciales JSON
# y coloca la ruta aquí:
# GOOGLE_APPLICATION_CREDENTIALS=config/google-credentials.json

# === RVC Configuration ===
# Device para procesamiento (auto, cuda, cpu, mps)
RVC_DEVICE=auto

# F0 extraction method (rmvpe, parselmouth, harvest)
RVC_F0_METHOD=rmvpe

# === Audio Configuration ===
# Dispositivo de salida de audio (deja vacío para usar por defecto)
AUDIO_OUTPUT_DEVICE=

# === Paths (avanzado) ===
# VOICES_DIR=voices
# CONFIG_DIR=config
# OUTPUTS_DIR=outputs
