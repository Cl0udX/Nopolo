# .env

# ==================== Rutas de RVC ====================
index_root=voices
weight_root=voices

# ==================== API REST Configuration ====================
API_ENABLED=true
API_HOST=0.0.0.0
API_PORT=8000
API_CORS_ENABLED=true

# ==================== GUI Configuration ====================
GUI_SHOW_API_CONTROLS=true
GUI_AUTO_START_API=false

# ==================== Voice Configuration ====================
VOICES_CONFIG_PATH=config/voices.json
EDGE_VOICES_JSON=config/edge_voices.json

# ==================== Audio Configuration ====================
DEFAULT_VOLUME=0.8
DEFAULT_TTS_VOICE=es-MX-JorgeNeural

# ==================== Logging ====================
LOG_LEVEL=INFO
VERBOSE_LOGGING=false